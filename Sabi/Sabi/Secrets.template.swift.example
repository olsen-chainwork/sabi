//
//  Secrets.template.swift.example
//  Sabi
//
//  This file intentionally does not end in `.swift`.
//  Xcode 16 filesystem-synced groups compile every Swift file in the folder,
//  which would make this placeholder collide with the real local Secrets.swift.
//
//  1. Copy this file to `Secrets.swift` in the same directory:
//        cp Secrets.template.swift.example Secrets.swift
//
//  2. Paste your real API keys into the two `REPLACE_ME` strings below.
//
//  3. Do NOT commit `Secrets.swift`. It's already in `.gitignore`.
//     This template file is safe to track because it only holds placeholders.
//
//  Getting the keys (both have free tiers):
//    - Anthropic:    console.anthropic.com  ->  Settings  ->  API Keys
//    - Brave Search: api-dashboard.search.brave.com  ->  API Keys
//

import Foundation

nonisolated enum Secrets {
    /// Anthropic API key. Used by AugmentPrompt (seed -> refined focus)
    /// and Ranker (candidates -> ranked list). Haiku 4.5 by default.
    static let anthropicAPIKey = "REPLACE_ME"

    /// Brave Search API subscription token. Used by BraveClient for
    /// site-restricted retrieval. Free tier is enough for dev work.
    static let braveAPIKey = "REPLACE_ME"
}
